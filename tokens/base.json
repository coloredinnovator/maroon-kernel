{
  "base": {
    "palette": {
      "white": "#ffffff",
      "black": "#000000",
      "blue": { "500": "#3b82f6", "600": "#2563eb" },
      "red": { "500": "#ef4444", "600": "#dc2626" },
      "gray": { "100": "#f3f4f6", "500": "#6b7280", "900": "#111827" }
    },
    "spacing": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px"
    },
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px"
    },
    "typography": {
      "fontFamily": {
        "sans": "Inter, system-ui, sans-serif",
        "mono": "JetBrains Mono, monospace"
      },
      "fontSize": {
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem"
      }
    },
    "motion": {
      "duration": {
        "fast": "150ms",
        "normal": "300ms",
        "slow": "500ms"
      }
    }
  },
  "semantic": {
    "intent": {
      "inform": { "color": "{base.palette.blue.600}" },
      "danger": { "color": "{base.palette.red.600}" },
      "success": { "color": "#10b981" }
    },
    "domain": {
      "default": { "accent": "{base.palette.blue.500}" },
      "legal": { "accent": "#4f46e5" },
      "crisis": { "accent": "{base.palette.red.600}", "highContrast": true }
    }
  }
}
